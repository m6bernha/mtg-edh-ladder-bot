# Dependencies
node_modules/

# Build output and local Wrangler state
dist/
.wrangler/
*.log

# Secrets — never commit these.
# .dev.vars holds your Discord bot token; see .dev.vars.example for the shape.
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example
*.pem
*.key

# Throwaway Ed25519 keypair generated by scripts/local-smoke.mjs
.smoke-keys.json

# Your own deployment config — it contains your Cloudflare D1 database_id and
# your chosen Worker name. Copy wrangler.example.jsonc to wrangler.jsonc and
# fill in your own values. See README.md → Self-hosting.
wrangler.jsonc

# OS cruft
.DS_Store
Thumbs.db
